---
import Base from "../layouts/Base.astro";
import HeroShell from "./HeroShell.astro";
import BottomNav from "./BottomNav.astro";
import { ShowRequestForm } from "./ShowRequestForm";
import { site } from "../content/site";
import { getKintanaEnv, hasKintanaCredentials } from "../lib/kintana-env";
import { fetchSiteManifest, endpointSlugFromManifest } from "../lib/kintana-site";
import "../styles/global.css";

const { apiKey, baseUrl } = getKintanaEnv();
const manifest = hasKintanaCredentials() ? await fetchSiteManifest() : null;
const endpointSlug = endpointSlugFromManifest(manifest, "showRequest", "contact");
---

<Base title={`Contact · ${site.artistName}`} description={site.contact.title}>
  <main class="page-main">
    <HeroShell scrollable={true}>
      <div class="page-panel">
        <div class="page-panel-inner">
          <h1 class="page-heading">{site.contact.title}</h1>
          <p class="page-lede">{site.contact.body}</p>

          <div class="contact-grid">
            <div class="contact-lines">
              <div class="contact-block">
                <p class="contact-label">Bookings</p>
                <a class="contact-value" href={`mailto:${site.bookingsEmail}`}>{site.bookingsEmail}</a>
              </div>
              <div class="contact-block">
                <p class="contact-label">General</p>
                <a class="contact-value" href={`mailto:${site.email}`}>{site.email}</a>
              </div>
              <div class="social-row">
                {
                  site.social.map((link) => (
                    <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
                  ))
                }
              </div>
            </div>

            {
              hasKintanaCredentials() ? (
                <div class="contact-form">
                  <ShowRequestForm
                    client:load
                    apiKey={apiKey!}
                    baseUrl={baseUrl!}
                    endpointSlug={endpointSlug}
                    mode="country"
                    className="contact-form-inner"
                  />
                </div>
              ) : null
            }
          </div>

          <p class="page-footer-note">
            {site.footerCredit.prefix}
            <a href={site.footerCredit.href} target="_blank" rel="noopener noreferrer">
              {site.footerCredit.label}
            </a>
          </p>
        </div>
      </div>
      <BottomNav currentPath="/contact/" />
    </HeroShell>
  </main>
</Base>
