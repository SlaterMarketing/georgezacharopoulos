---
import type { KintanaPublicEvent } from "@kintana/sdk";
import { eventSupportsEmbedCheckout, isTicketingBlocked } from "../../lib/events";

interface Props {
  event: KintanaPublicEvent;
}

const { event } = Astro.props;
const blocked = isTicketingBlocked(event);
const canEmbed = eventSupportsEmbedCheckout(event);
const externalTicketUrl = event.ticketUrl?.trim() || "";
---

{
  blocked ? (
    <p class="show-unavailable">
      Ticketing is unavailable
      {event.status === "sold-out" ? " — this show is sold out." : "."}
    </p>
  ) : canEmbed ? (
    <div class="ticket-widget-wrap">
      <div class="ticket-widget" data-kintana-widget={`event:${event.id}`} aria-label="Ticket checkout" />
      <p class="ticket-widget-loading">Loading tickets…</p>
    </div>
  ) : externalTicketUrl ? (
    <p class="ticket-widget-fallback">
      <a class="show-ticket-link" href={externalTicketUrl} target="_blank" rel="noopener noreferrer">
        Get tickets
      </a>
    </p>
  ) : (
    <p class="show-unavailable">Ticketing is unavailable for this show.</p>
  )
}
