---
import SiteLayout from "./SiteLayout.astro";
import { site } from "../content/site";
import "../styles/global.css";
---

<SiteLayout title={`Solo shows · ${site.artistName}`} description={`Solo hours and festival shows from ${site.artistName}.`}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow light">Solo hours</p>
      <h1 class="section-title">{site.tagline}</h1>
      <p class="body-copy">Award-winning solo shows from clubs to fringe festivals.</p>
    </div>
  </section>

  <section class="page-content">
    <div class="container page-content--narrow">
      <ul class="solo-list">
        {
          site.soloShows.map((show) => (
            <li class="solo-item">
              <h2>{show.title}</h2>
              {show.year ? <p class="solo-item-meta">{show.year}</p> : null}
              <p class="body-copy">{show.body}</p>
              {show.href ? (
                <a class="text-link" href={show.href} target="_blank" rel="noopener noreferrer">
                  Learn more →
                </a>
              ) : null}
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</SiteLayout>
