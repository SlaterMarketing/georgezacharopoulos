---
import Base from "../layouts/Base.astro";
import HeroShell from "./HeroShell.astro";
import BottomNav from "./BottomNav.astro";
import { site } from "../content/site";
import "../styles/global.css";
---

<Base title={`Solo shows · ${site.artistName}`} description={`Solo hours and festival shows from ${site.artistName}.`}>
  <main class="page-main">
    <HeroShell scrollable={true}>
      <div class="page-panel">
        <div class="page-panel-inner">
          <h1 class="page-heading">Solo shows</h1>
          <p class="page-lede">Award-winning solo hours from the Greek Comedian of the Year.</p>

          <ul class="solo-shows-list">
            {
              site.soloShows.map((show) => (
                <li class="solo-show-card">
                  <h2>{show.title}</h2>
                  <p>{show.body}</p>
                  {show.href ? (
                    <a class="text-link" href={show.href} target="_blank" rel="noopener noreferrer">
                      Learn more →
                    </a>
                  ) : null}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
      <BottomNav currentPath="/solo-shows/" />
    </HeroShell>
  </main>
</Base>
