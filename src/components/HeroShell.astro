---
import { site } from "../content/site";

interface Props {
  showTitle?: boolean;
  scrollable?: boolean;
}

const { showTitle = false, scrollable = false } = Astro.props;
---

<div class:list={["hero-shell", scrollable && "hero-shell--scroll"]}>
  <div class="hero-bg hero-bg--mobile" style={`background-image: url(${site.heroImageMobile})`} aria-hidden="true"></div>
  <div class="hero-bg hero-bg--desktop" style={`background-image: url(${site.heroImage})`} aria-hidden="true"></div>
  <div class="hero-shade" aria-hidden="true"></div>

  {
    showTitle ? (
      <div class="hero-title-lockup" aria-hidden="true">
        <span class="hero-title-line">Michael</span>
        <span class="hero-title-line">Bevan</span>
      </div>
    ) : null
  }

  <div class="hero-shell-content">
    <slot />
  </div>
</div>
