---
import { site } from "../content/site";
import type { KintanaPublicEvent } from "@kintana/sdk";
import {
  eventCity,
  eventShowHref,
  eventTicketsHref,
  eventVenue,
  formatShowDate,
  ticketLinkLabel,
} from "../lib/events";

interface Props {
  events: KintanaPublicEvent[];
  heading?: string;
  showHeading?: boolean;
  compact?: boolean;
}

const { events, heading = site.showsHeading, showHeading = true, compact = false } = Astro.props;
---

<section class:list={["gigs-section", compact && "gigs-section--compact"]}>
  {showHeading ? <h2 class="section-title">{heading}</h2> : null}

  {
    events.length === 0 ? (
      <p class="empty-note">{site.noShowsMessage}</p>
    ) : (
      <ul class="gigs-list">
        {
          events.map((event) => {
            const showHref = eventShowHref(event);
            const ticketsHref = eventTicketsHref(event);
            return (
              <li class="gig-row">
                <div class="gig-date">{formatShowDate(event.date)}</div>
                <div class="gig-info">
                  {
                    showHref ? (
                      <a class="gig-name" href={showHref}>
                        {event.name}
                      </a>
                    ) : (
                      <p class="gig-name">{event.name}</p>
                    )
                  }
                  <p class="gig-venue">
                    {eventVenue(event)} · {eventCity(event)}
                  </p>
                </div>
                <a
                  class="btn btn-primary btn-sm"
                  href={ticketsHref}
                  {...showHref ? {} : { target: "_blank", rel: "noopener noreferrer" }}
                >
                  {ticketLinkLabel(event)}
                </a>
              </li>
            );
          })
        }
      </ul>
    )
  }
</section>
