---
import SiteLayout from "./SiteLayout.astro";
import { ShowRequestForm } from "./ShowRequestForm";
import { site } from "../content/site";
import { getKintanaEnv, hasKintanaCredentials } from "../lib/kintana-env";
import { fetchSiteManifest, endpointSlugFromManifest } from "../lib/kintana-site";
import "../styles/global.css";

const { apiKey, baseUrl } = getKintanaEnv();
const manifest = hasKintanaCredentials() ? await fetchSiteManifest() : null;
const endpointSlug = endpointSlugFromManifest(manifest, "showRequest", "contact");
---

<SiteLayout title={`Request a show · ${site.artistName}`} description={`Request ${site.artistName} in your city.`} headerOverlay={true}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow light">Your city</p>
      <h1 class="section-title">Bring George to your town</h1>
      <p class="body-copy">Tell us where you are — we&apos;ll reach out when routing makes sense.</p>
    </div>
  </section>

  <section class="page-content">
    <div class="container page-content--narrow">
      {
        hasKintanaCredentials() ? (
          <div class="contact-form-panel">
            <ShowRequestForm
              client:load
              apiKey={apiKey!}
              baseUrl={baseUrl!}
              endpointSlug={endpointSlug}
              mode="country"
              className="contact-form-inner"
            />
          </div>
        ) : (
          <p class="muted">Request form will appear here once Kintana is connected.</p>
        )
      }
    </div>
  </section>
</SiteLayout>
