---
import SiteLayout from "./SiteLayout.astro";
import { site } from "../content/site";
import "../styles/global.css";
---

<SiteLayout title={`Bio · ${site.artistName}`} description={site.description}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow light">About</p>
      <h1 class="section-title">From Kalamata to headline clubs</h1>
      <p class="body-copy">Also known as {site.alsoKnownAs} — when British comperes give up on the surname.</p>
    </div>
  </section>

  <section class="page-content">
    <div class="container bio-layout">
      <figure class="bio-portrait">
        <img src="/gallery/01.webp" alt="George Zacharopoulos performing stand-up" loading="eager" />
        <figcaption>Photo from the dating-app era. It worked.</figcaption>
      </figure>

      <div class="bio-copy prose">
        {site.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}

        <div class="awards-block">
          <h2 class="section-title">Awards</h2>
          <ul>
            {site.awards.map((award) => <li>{award}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
