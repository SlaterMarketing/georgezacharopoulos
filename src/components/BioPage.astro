---
import Base from "../layouts/Base.astro";
import HeroShell from "./HeroShell.astro";
import BottomNav from "./BottomNav.astro";
import { site } from "../content/site";
import "../styles/global.css";

function stars(count: number) {
  return "★".repeat(count);
}
---

<Base title={`Bio · ${site.artistName}`} description={site.description}>
  <main class="page-main">
    <HeroShell scrollable={true}>
      <div class="page-panel">
        <div class="page-panel-inner">
          <h1 class="page-heading">Bio</h1>
          <div class="bio-prose">
            {site.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>

          <section class="awards-section">
            <h2 class="section-heading">Awards</h2>
            <ul class="awards-list">
              {site.awards.map((award) => <li>{award}</li>)}
            </ul>
          </section>

          <section class="reviews-section">
            <h2 class="section-heading">Press</h2>
            <ul class="reviews-list">
              {
                site.reviews.slice(0, 3).map((review) => (
                  <li>
                    {review.quote ? (
                      <>
                        &lsquo;{review.quote}&rsquo; {stars(review.stars)} {review.source}
                      </>
                    ) : (
                      <>
                        {stars(review.stars)} {review.source}
                      </>
                    )}
                  </li>
                ))
              }
            </ul>
            <a class="text-link" href="/press/">All press quotes →</a>
          </section>
        </div>
      </div>
      <BottomNav currentPath="/bio/" />
    </HeroShell>
  </main>
</Base>
