---
import SiteLayout from "./SiteLayout.astro";
import PressQuotes from "./PressQuotes.astro";
import { site } from "../content/site";
import "../styles/global.css";
---

<SiteLayout title={`Press · ${site.artistName}`} description={`Press quotes and reviews for ${site.artistName}.`} headerOverlay={true}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow light">Reviews</p>
      <h1 class="section-title">Press quotes</h1>
      <p class="body-copy">What critics and festival reviewers have said.</p>
    </div>
  </section>

  <section class="page-content">
    <div class="container">
      <PressQuotes reviews={site.reviews} />
    </div>
  </section>
</SiteLayout>
