---
import SiteLayout from "./SiteLayout.astro";
import { site } from "../content/site";
import "../styles/global.css";
---

<SiteLayout title={`Gallery · ${site.artistName}`} description={`Photos from ${site.artistName}'s live shows and festivals.`}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow light">Photos</p>
      <h1 class="section-title">{site.gallery.title}</h1>
      <p class="body-copy">Live shots from clubs, festivals, and rooms that survived the experience.</p>
    </div>
  </section>

  <section class="page-content">
    <div class="container">
      <ul class="gallery-grid">
        {
          site.gallery.images.map((image, index) => (
            <li class:list={["gallery-item", index === 0 && "gallery-item--feature"]}>
              <img src={image.src} alt={image.alt} loading={index < 3 ? "eager" : "lazy"} decoding="async" />
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</SiteLayout>
