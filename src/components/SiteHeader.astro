---
import { site } from "../content/site";

interface Props {
  currentPath?: string;
  nextShowHref?: string | null;
}

const { currentPath = Astro.url.pathname, nextShowHref = null } = Astro.props;

function isActive(href: string) {
  if (href === "/") return currentPath === "/" || currentPath === "";
  return currentPath.startsWith(href.replace(/\/$/, ""));
}
---

<header class="site-header" data-site-header>
  <div class="container site-header-inner">
    <a class="site-logo" href="/">{site.artistName}</a>

    <button
      type="button"
      class="menu-toggle"
      aria-expanded="false"
      aria-controls="mobile-nav"
      data-menu-toggle
    >
      <span></span>
      <span></span>
      <span class="sr-only">Menu</span>
    </button>

    <div class="site-header-nav" id="mobile-nav" data-mobile-panel>
      <nav class="site-nav" aria-label="Primary">
        {
          site.nav.map((item) => (
            <a class:list={["nav-link", { "is-active": isActive(item.href) }]} href={item.href}>
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="header-actions">
        {
          nextShowHref ? (
            <a class="btn btn-primary btn-sm" href={nextShowHref}>Get tickets</a>
          ) : null
        }
        <a class="btn btn-ghost btn-sm" href="/contact/">Contact</a>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector("[data-site-header]");
  if (header instanceof HTMLElement) {
    const onScroll = () => {
      header.classList.toggle("is-scrolled", window.scrollY > 24);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  const toggle = document.querySelector("[data-menu-toggle]");
  const panel = document.querySelector("[data-mobile-panel]");
  if (toggle instanceof HTMLButtonElement && panel instanceof HTMLElement) {
    toggle.addEventListener("click", () => {
      const open = panel.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
      document.body.classList.toggle("nav-open", open);
    });
    panel.querySelectorAll(".nav-link, .header-actions a").forEach((link) => {
      link.addEventListener("click", () => {
        panel.classList.remove("is-open");
        toggle.setAttribute("aria-expanded", "false");
        document.body.classList.remove("nav-open");
      });
    });
  }
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
