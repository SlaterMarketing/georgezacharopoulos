---
import Base from "../layouts/Base.astro";
import HeroShell from "./HeroShell.astro";
import BottomNav from "./BottomNav.astro";
import ShowsSection from "./ShowsSection.astro";
import { site } from "../content/site";
import { createKintanaClientFromEnv, hasKintanaCredentials } from "../lib/kintana-env";
import type { KintanaPublicEvent } from "@kintana/sdk";
import "../styles/global.css";

let events: KintanaPublicEvent[] = [];

if (hasKintanaCredentials()) {
  try {
    events = await createKintanaClientFromEnv().listEvents({ limit: 50 });
  } catch (error) {
    if (import.meta.env.DEV) {
      console.error("[georgezacharopoulos] listEvents failed:", error);
    }
  }
}
---

<Base title={`Tickets · ${site.artistName}`} description={site.showsHeading}>
  <main class="page-main">
    <HeroShell scrollable={true}>
      <div class="page-panel">
        <div class="page-panel-inner">
          <ShowsSection events={events} />
        </div>
      </div>
      <BottomNav currentPath="/shows/" />
    </HeroShell>
  </main>
</Base>
