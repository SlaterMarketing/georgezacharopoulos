---
import SiteLayout from "./SiteLayout.astro";
import GigsList from "./GigsList.astro";
import { site } from "../content/site";
import { createKintanaClientFromEnv, hasKintanaCredentials } from "../lib/kintana-env";
import { reserveTicketHref } from "../lib/events";
import type { KintanaPublicEvent } from "@kintana/sdk";
import "../styles/global.css";

let events: KintanaPublicEvent[] = [];

if (hasKintanaCredentials()) {
  try {
    events = await createKintanaClientFromEnv().listEvents({ limit: 50 });
  } catch (error) {
    if (import.meta.env.DEV) {
      console.error("[georgezacharopoulos] listEvents failed:", error);
    }
  }
}
---

<SiteLayout
  title={`Gigs · ${site.artistName}`}
  description={site.showsHeading}
  nextShowHref={reserveTicketHref(events)}
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow light">Live dates</p>
      <h1 class="section-title">{site.showsHeading}</h1>
      <p class="body-copy">Catch George live across the UK, Europe, Dubai, and Australia.</p>
    </div>
  </section>

  <section class="page-content">
    <div class="container">
      <GigsList events={events} showHeading={false} />
    </div>
  </section>
</SiteLayout>
