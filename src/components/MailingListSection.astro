---
import { NewsletterForm } from "./NewsletterForm";
import { site } from "../content/site";
import { getKintanaEnv, hasKintanaCredentials } from "../lib/kintana-env";
import { fetchSiteManifest, endpointSlugFromManifest } from "../lib/kintana-site";

const { apiKey, baseUrl } = getKintanaEnv();
const manifest = hasKintanaCredentials() ? await fetchSiteManifest() : null;
const endpointSlug = endpointSlugFromManifest(manifest, "newsletter", "newsletter");
---

<section class="mailing-section" id="mailing">
  <div class="container mailing-inner">
    <div class="mailing-copy">
      <p class="section-eyebrow section-eyebrow--light">Stay in the loop</p>
      <h2 class="mailing-title">{site.mailingList.title}</h2>
      <p class="mailing-lede">{site.mailingList.body}</p>
    </div>

    {
      hasKintanaCredentials() ? (
        <div class="mailing-form">
          <NewsletterForm
            client:load
            apiKey={apiKey!}
            baseUrl={baseUrl!}
            endpointSlug={endpointSlug}
            className="mailing-form-inner"
          />
        </div>
      ) : (
        <p class="mailing-fallback">Mailing list signup will appear here once connected.</p>
      )
    }
  </div>
</section>
